NODE_ENV=development

# AWS Secrets Manager secret names (used in non-dev environments)
SECRETS_JWT_SECRET_NAME=orders-api/dev/jwt-secret
SECRETS_MONGODB_URI_NAME=orders-api/dev/mongodb-uri
SECRETS_REDIS_URL_NAME=orders-api/dev/redis-url

# Direct values for local development only (never commit real values)
JWT_SECRET=local-dev-secret-change-me

# When running with Node.js directly (npm run dev)
MONGODB_URI=mongodb://localhost:27017/orders-dev
REDIS_URL=redis://localhost:6379
# Note: when using Docker (docker compose up), MONGODB_URI and REDIS_URL
# are overridden in docker-compose.yml to use container service names.

JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_AUDIENCE=orders-api
JWT_ISSUER=orders-api

CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_API_MAX=200
